# AutoXPost configuration
# Copy this file to `.env` and fill in the tokens for the platforms you want.

# --- General ----------------------------------------------------------------
# SQLite database file for the post queue.
AUTOXPOST_DB=./autoxpost.db
AUTOXPOST_LOG_LEVEL=INFO

# --- X (Twitter) ------------------------------------------------------------
# OAuth 1.0a user-context auth. Create an app at https://developer.twitter.com/
# and generate the access tokens for your personal account.
X_BEARER_TOKEN=
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
# X_CHAR_LIMIT is auto-detected from the API response; override only if you
# know the account is on a non-standard tier.
X_CHAR_LIMIT=

# --- Mastodon ---------------------------------------------------------------
# Use any Mastodon instance. Generate an access token under
# Preferences > Development > New Application.
MASTODON_BASE_URL=
MASTODON_ACCESS_TOKEN=

# --- Bluesky ----------------------------------------------------------------
# App password from https://bsky.app/settings/app-passwords
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=
# Optional: custom PDS (defaults to https://api.bsky.app)
BLUESKY_PDS=

# --- LinkedIn ---------------------------------------------------------------
# OAuth2 user token with w_member_social scope.
# Get the author URN by calling /v2/userinfo with the access token.
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=

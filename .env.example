# AutoXPost configuration
# Copy this file to `.env` and fill in the tokens for the platforms you want.

# --- General ----------------------------------------------------------------
# SQLite database file for the post queue.
AUTOXPOST_DB=./autoxpost.db
AUTOXPOST_LOG_LEVEL=INFO

# --- X (Twitter) ------------------------------------------------------------
# OAuth 1.0a user-context auth. Create an app at https://developer.twitter.com/
# and generate the access tokens for your personal account.
X_BEARER_TOKEN=
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
# X_CHAR_LIMIT is auto-detected from the API response; override only if you
# know the account is on a non-standard tier.
X_CHAR_LIMIT=

# --- Mastodon ---------------------------------------------------------------
# Use any Mastodon instance. Generate an access token under
# Preferences > Development > New Application.
MASTODON_BASE_URL=
MASTODON_ACCESS_TOKEN=

# --- Bluesky ----------------------------------------------------------------
# App password from https://bsky.app/settings/app-passwords
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=
# Optional: custom PDS (defaults to https://api.bsky.app)
BLUESKY_PDS=

# --- LinkedIn ---------------------------------------------------------------
# OAuth2 user token with w_member_social scope.
# Get the author URN by calling /v2/userinfo with the access token.
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=

# --- Threads (Meta) ---------------------------------------------------------
# Long-lived user access token (valid 60 days, refreshable).
# Get it via the Threads API OAuth flow with the threads_basic and
# threads_content_publish scopes. Numeric Threads user ID comes from
# GET /me?fields=id with the same token.
THREADS_USER_ID=
THREADS_ACCESS_TOKEN=

# --- Risk control (auto-enabled; defaults are conservative for new accounts) -
# Master switch. Set to false to bypass every safety check (not recommended).
AUTOXPOST_SAFETY_ENABLED=true
# Hours to look back when checking for duplicate posts on the same platform.
AUTOXPOST_DUPLICATE_WINDOW_HOURS=24
# How many recent posted-hashes to keep per platform for dedup (older rows pruned).
AUTOXPOST_HASH_HISTORY=200

# Per-platform overrides follow the pattern AUTOXPOST_<UPPER>_<FIELD>.
# Examples (defaults are in src/autoxpost/core/safety.py):

# X (Twitter) — defaults: 90s / 50/day / burst 5/h / jitter 15-60s / cooldown 30m
# AUTOXPOST_X_MIN_INTERVAL_SECONDS=90
# AUTOXPOST_X_DAILY_CAP=50
# AUTOXPOST_X_BURST_CAP=5
# AUTOXPOST_X_JITTER_MIN_SECONDS=15
# AUTOXPOST_X_JITTER_MAX_SECONDS=60
# AUTOXPOST_X_COOLDOWN_MINUTES=30
# AUTOXPOST_X_KILL_SWITCH_THRESHOLD=5

# Mastodon — defaults: 60s / 300/day / burst 10/h / jitter 10-45s / cooldown 15m
# AUTOXPOST_MASTODON_MIN_INTERVAL_SECONDS=60
# AUTOXPOST_MASTODON_DAILY_CAP=300
# AUTOXPOST_MASTODON_BURST_CAP=10
# AUTOXPOST_MASTODON_COOLDOWN_MINUTES=15

# Bluesky — defaults: 30s / 1500/day / burst 30/h / jitter 5-20s / cooldown 15m
# AUTOXPOST_BLUESKY_MIN_INTERVAL_SECONDS=30
# AUTOXPOST_BLUESKY_DAILY_CAP=1500

# LinkedIn — defaults: 300s / 50/day / burst 3/h / jitter 60-180s / cooldown 60m
# AUTOXPOST_LINKEDIN_MIN_INTERVAL_SECONDS=300
# AUTOXPOST_LINKEDIN_DAILY_CAP=50
# AUTOXPOST_LINKEDIN_BURST_CAP=3
# AUTOXPOST_LINKEDIN_COOLDOWN_MINUTES=60
# AUTOXPOST_LINKEDIN_KILL_SWITCH_THRESHOLD=3

# Threads — defaults: 60s / 50/day / burst 10/h / jitter 10-45s / cooldown 15m
# AUTOXPOST_THREADS_MIN_INTERVAL_SECONDS=60
# AUTOXPOST_THREADS_DAILY_CAP=50
# AUTOXPOST_THREADS_BURST_CAP=10
# AUTOXPOST_THREADS_COOLDOWN_MINUTES=15
